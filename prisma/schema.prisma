// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  
}

model User {
  id                 String   @id @default(uuid())
  clerkId            String   @unique  // حاسم لربط حساب الطالب بنظام الحماية
  email              String   @unique
  
  // بيانات شاشة الاستقبال
  firstName          String?
  fatherName         String?
  birthYear          String?
  onboardingComplete Boolean  @default(false) 
  
  role               Role     @default(STUDENT)
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  // العلاقات (Relations)
  devices            Device[]
  purchases          Purchase[]
  usedCodes          CourseCode[] // الكروت التي استخدمها الطالب
}

enum Role {
  STUDENT
  TEACHER   // أضفنا صلاحية الأستاذ
  ADMIN
}

// جدول بصمة الأجهزة لمنع مشاركة الحسابات
model Device {
  id           String   @id @default(uuid())
  userId       String
  deviceFinger String   @unique
  deviceName   String?
  isApproved   Boolean  @default(true)
  lastUsedAt   DateTime @default(now())
  createdAt    DateTime @default(now())

  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

// جدول الكورسات
model Course {
  id          String   @id @default(uuid())
  title       String
  description String?
  price       Float
  videoUrl    String?
  isPublished Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  purchases   Purchase[]
  codes       CourseCode[] // الأكواد التابعة لهذا الكورس
}

// جدول الكروت والأكواد المطبوعة (نظام الدفع الفعلي للمكتبات)
model CourseCode {
  id        String    @id @default(uuid())
  code      String    @unique // الكود السري المطبوع على البطاقة
  courseId  String    
  course    Course    @relation(fields: [courseId], references: [id], onDelete: Cascade)
  
  isUsed    Boolean   @default(false) 
  userId    String?   
  user      User?     @relation(fields: [userId], references: [id])
  
  usedAt    DateTime? 
  createdAt DateTime  @default(now())
}

// جدول الدفع الإلكتروني (نحتفظ به للمستقبل)
model Purchase {
  id            String        @id @default(uuid())
  userId        String
  courseId      String
  amount        Float
  status        PaymentStatus @default(PENDING)
  provider      String
  transactionId String?       @unique
  createdAt     DateTime      @default(now())

  user          User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  course        Course        @relation(fields: [courseId], references: [id], onDelete: Cascade)

  @@unique([userId, courseId])
}

enum PaymentStatus {
  PENDING
  SUCCESS
  FAILED
}